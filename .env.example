# ============================================================
# Shopify ↔ Sage BusinessWorks Middleware Agent — Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Shopify Settings ---
SHOPIFY_STORE_URL=https://your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2024-04
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret

# --- Sage BusinessWorks ODBC Settings ---
# The DSN name as configured in Windows ODBC Data Source Administrator (32-bit)
BW_ODBC_DSN=SageBusinessWorks
BW_ODBC_USER=
BW_ODBC_PASSWORD=

# --- BWGACCESS Settings ---
# Full path to the BWGACCESS.exe on the Windows machine
BWGACCESS_EXE_PATH=C:\SageBusinessWorks\BWGACCESS\BWGACCESS.exe
# Folder where CSV import files are staged before BWGACCESS picks them up
BWGACCESS_IMPORT_DIR=C:\SageBusinessWorks\imports
# Folder where BWGACCESS writes export files
BWGACCESS_EXPORT_DIR=C:\SageBusinessWorks\exports
# Company data directory used by BWGACCESS
BWGACCESS_COMPANY_DIR=C:\SageBusinessWorks\Company

# --- Sync Schedule (cron syntax) ---
# How often to poll for inventory changes (default: every 10 minutes)
SYNC_INVENTORY_CRON=*/10 * * * *
# How often to check for new BW orders/fulfillments (default: every 5 minutes)
SYNC_FULFILLMENT_CRON=*/5 * * * *
# How often to sync customer records (default: hourly)
SYNC_CUSTOMERS_CRON=0 * * * *
# How often to sync product/pricing updates from BW (default: every 30 minutes)
SYNC_PRODUCTS_CRON=*/30 * * * *

# --- Webhook HTTP Server ---
# Port the agent listens on for incoming Shopify webhooks
WEBHOOK_PORT=3456
# Set to true to verify webhook HMAC signatures from Shopify
WEBHOOK_VERIFY_HMAC=true

# --- Agent Settings ---
# Log level: error | warn | info | debug
LOG_LEVEL=info
# Max number of days to keep log files
LOG_RETENTION_DAYS=30
# Directory to write log files
LOG_DIR=C:\SageBusinessWorks\AgentLogs
# Number of parallel sync operations allowed
QUEUE_CONCURRENCY=3
# Milliseconds to wait between Shopify API calls (rate limit buffer)
SHOPIFY_API_DELAY_MS=500
